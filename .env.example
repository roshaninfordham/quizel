# Phone-reachable URLs used by make online.
# Leave blank for automatic LAN IP detection, or set PUBLIC_BASE_URL when using a tunnel.
QUIZRUSH_LAN_HOST=
PUBLIC_BASE_URL=
PUBLIC_REALTIME_URL=
VITE_PUBLIC_APP_URL=
TUNNEL_PROVIDER=none

# Browser realtime server.
# Leave blank in normal demos; make online injects ws://YOUR_LAPTOP_IP:5173/quizrush-ws.
VITE_REALTIME_URL=

# SpacetimeDB connection placeholders.
VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_MODULE=quizrush-live

# Agent worker transport.
AGENT_WORKER_MODE=watch
AGENT_TRANSPORT=local
AGENT_REALTIME_URL=ws://127.0.0.1:8787

# LLM provider-neutral worker configuration.
# Use LLM_PROVIDER_NAME=auto to select the first configured provider below.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL_ID=
LLM_SMALL_MODEL_ID=
LLM_PROVIDER_NAME=auto
LLM_TIMEOUT_MS=12000
LLM_MAX_RETRIES=2
LLM_JSON_MODE=true

# OpenAI-compatible direct provider.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SMALL_MODEL=gpt-4.1-mini

# Anthropic provider.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SMALL_FAST_MODEL=claude-3-5-haiku-20241022

# Gemini provider.
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SMALL_MODEL=gemini-2.5-flash

# NVIDIA NIM / NVIDIA-hosted OpenAI-compatible provider.
# Put real nvapi keys only in .env.local.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_AUTHOR_API_KEY=
NVIDIA_AUTHOR_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_REASONING_API_KEY=
NVIDIA_REASONING_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_SMALL_API_KEY=
NVIDIA_SMALL_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_SAFETY_API_KEY=
NVIDIA_SAFETY_MODEL=nvidia/llama-3.1-nemotron-safety-guard-8b-v3
NVIDIA_JSON_MODE=false
NVIDIA_REASONING_ENABLED=false
SAFETY_GUARD_ENABLED=false

QUIZ_TOPIC="AI + Space + Startups"
QUIZ_QUESTION_COUNT=5

# Demo controls.
DEMO_MODE=true
SEED_DEMO_DATA=true
